APP_NAME=Tableau de bord DPI API
APP_ENV=production

# Option A: set a complete SQLAlchemy URL.
DATABASE_URL=

# Option B: leave DATABASE_URL empty and set these MySQL values.
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

SQL_TABLE_NAME=suivi_dpi_sites
